# GFW 域名转发到这里（路由器上是 10.220.10.253:53）
GFW_UPSTREAM_IP=10.220.10.253
GFW_UPSTREAM_PORT=53

# 其他域名的默认上游（多个用空格分隔，会逐一展开成 server= 行）
DEFAULT_UPSTREAM=223.5.5.5 119.29.29.29

# 每天自动更新 gfwlist 的时间（busybox crontab 格式，容器时区 = TZ）
UPDATE_CRON=0 4 * * *

# 容器时区（影响 cron 触发时间和日志）
TZ=Asia/Shanghai

# 宿主上对外暴露的 DNS 端口（默认 5300，避开 systemd-resolved 占用的 53）
DNS_PORT=5300
